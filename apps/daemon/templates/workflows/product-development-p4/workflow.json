{
  "$schema": "../workflow.schema.json",
  "name": "product-development-p4",
  "description": "Product development workflow for Perforce teams with sync and shelve phases",
  "version": "1.0.1",
  "parentTemplate": "product-development",
  "phases": [
    {
      "id": "Refinement",
      "name": "Refinement",
      "description": "Refine brainstormed ideas into clear, actionable requirements",
      "workers": [
        {
          "id": "refinement-ralph-loop",
          "type": "ralphLoop",
          "description": "Creates refinement draft from brainstorm",
          "maxAttempts": 3,
          "workers": [
            {
              "id": "refinement-agent",
              "type": "agent",
              "source": "agents/refinement.md",
              "description": "Creates refinement draft from brainstorm",
              "modelTier": "high"
            },
            {
              "id": "adversarial-refinement-agent",
              "type": "agent",
              "source": "agents/adversarial-refinement.md",
              "description": "Reviews refinement draft and identifies gaps",
              "modelTier": "high"
            }
          ]
        }
      ],
      "transitions": {
        "next": "Backlog"
      }
    },
    {
      "id": "Backlog",
      "name": "Backlog",
      "description": "Approved requirements ready for architecture design",
      "workers": [],
      "transitions": {
        "next": null,
        "manual": true
      }
    },
    {
      "id": "Architecture",
      "name": "Architecture",
      "description": "Design technical architecture based on refinement",
      "blocksOnUnsatisfiedTiers": ["artifact-ready"],
      "workers": [
        {
          "id": "architecture-ralph-loop",
          "type": "ralphLoop",
          "description": "Creates architecture draft from refinement",
          "maxAttempts": 3,
          "workers": [
            {
              "id": "architect-agent",
              "type": "agent",
              "source": "agents/architect.md",
              "description": "Creates architecture draft from refinement",
              "disallowTools": ["Skill(superpowers:*)"],
              "modelTier": "high"
            },
            {
              "id": "adversarial-architect-agent",
              "type": "agent",
              "source": "agents/adversarial-architect.md",
              "description": "Reviews architecture draft and identifies issues",
              "modelTier": "high"
            }
          ]
        }
      ],
      "transitions": {
        "next": "Architecture Review"
      }
    },
    {
      "id": "Architecture Review",
      "name": "Architecture Review",
      "description": "Human review of architecture before specification",
      "workers": [],
      "transitions": {
        "next": null,
        "manual": true
      }
    },
    {
      "id": "Specification",
      "name": "Specification",
      "description": "Create detailed implementation specification with wave-based tickets",
      "unblocksTier": "artifact-ready",
      "workers": [
        {
          "id": "specification-agent",
          "type": "agent",
          "source": "agents/specification.md",
          "description": "Creates executable specification from architecture",
          "disallowTools": ["TaskCreate", "TaskUpdate", "Skill(superpowers:*)"],
          "modelTier": "high"
        }
      ],
      "transitions": {
        "next": "Specification Review"
      }
    },
    {
      "id": "Specification Review",
      "name": "Specification Review",
      "description": "Human review of specification before build",
      "workers": [],
      "transitions": {
        "next": null,
        "manual": true
      }
    },
    {
      "id": "Build",
      "name": "Build",
      "description": "Execute specification tickets in waves with QA validation",
      "blocksOnUnsatisfiedTiers": ["code-ready"],
      "workers": [
        {
          "id": "taskmaster-agent",
          "type": "agent",
          "source": "agents/taskmaster.md",
          "description": "Creates build tickets from specification",
          "disallowTools": ["Skill(superpowers:*)"],
          "modelTier": "mid"
        },
        {
          "id": "build-task-loop",
          "type": "taskLoop",
          "description": "Executes individual build tickets from specification",
          "maxAttempts": 100,
          "workers": [
            {
              "id": "sync-agent",
              "type": "agent",
              "source": "agents/sync-agent.md"
            },
            {
              "id": "build-ralph-loop",
              "type": "ralphLoop",
              "description": "Executes individual build tickets from specification",
              "maxAttempts": 2,
              "workers": [
                {
                  "id": "builder-agent",
                  "type": "agent",
                  "source": "agents/builder.md",
                  "description": "Executes individual build tickets from specification",
                  "disallowTools": ["Skill(superpowers:*)"],
                  "modelTier": "low"
                },
                {
                  "id": "verify-spec-agent",
                  "type": "agent",
                  "source": "agents/verify-spec.md",
                  "description": "Verifies the specification of the individual build tasks against the specification",
                  "modelTier": "low"
                },
                {
                  "id": "verify-quality-agent",
                  "type": "agent",
                  "source": "agents/verify-quality.md",
                  "description": "Verifies the quality of the individual build task code",
                  "disallowTools": ["TodoWrite"],
                  "modelTier": "low"
                }
              ]
            }
          ]
        },
        {
          "id": "qa-agent",
          "type": "agent",
          "source": "agents/qa.md",
          "description": "Creates build tickets from specification",
          "modelTier": "low"
        }
      ],
      "transitions": {
        "next": "Shelve"
      },
      "requiresIsolation": true
    },
    {
      "id": "Shelve",
      "name": "Shelve",
      "description": "Shelve changelist for review",
      "workers": [
        {
          "id": "shelve-agent",
          "type": "agent",
          "source": "agents/shelve-agent.md"
        }
      ],
      "transitions": {
        "next": null
      },
      "requiresIsolation": true
    }
  ]
}

